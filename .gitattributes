# Normalize line endings: the repository stores text as LF. Without this,
# Windows checkouts (autocrlf) make gofmt and other tools see CRLF and report
# spurious diffs. Go sources are committed and checked out as LF everywhere.
* text=auto eol=lf

*.go    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.sh    text eol=lf

# Windows-only scripts keep CRLF.
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binaries must never be normalized.
*.exe   binary
*.png   binary
*.jpg   binary
*.gif   binary
*.raw   binary
